# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://notes_user:notes_pass@postgres:5432/notesdb
DIRECT_URL=postgresql://notes_user:notes_pass@localhost:5432/notesdb

# ── Auth providers ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Storage (for audio uploads) ───────────────────────
